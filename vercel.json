{
  "rewrites": [
    {
      "source": "/css/:path*",
      "destination": "/site/css/:path*"
    },
    {
      "source": "/fonts/:path*",
      "destination": "/site/fonts/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "/site/images/:path*"
    },
    {
      "source": "/js/:path*",
      "destination": "/site/js/:path*"
    },
    {
      "source": "/rankings/:path*",
      "destination": "/site/index.html"
    },
    {
      "source": "/docs/:path*",
      "destination": "/site/index.html"
    },
    {
      "source": "/",
      "destination": "/site/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/site/index.html"
    }
  ]
}
