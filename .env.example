DISCORD_TOKEN=put_your_bot_token_here
CLIENT_ID=put_your_application_client_id_here
GUILD_ID=put_your_server_id_here

# Optional. Defaults are shown.
CONFIG_PATH=./config.json
DATA_PATH=./data/state.json

# Optional PostgreSQL + website API. Leave DATABASE_URL empty to use JSON fallback only.
DATABASE_URL=postgres://user:password@localhost:5432/itstiers
DATABASE_SSL=false
API_ENABLED=true
API_PORT=3000
CORS_ORIGIN=*

# Optional. Keeps the PvPClub token server-side and proxies it through /api/v2/pvpclub/:uuid.
PVPCLUB_TOKEN=

# Optional. Serve a downloaded/static frontend from the same API server.
STATIC_SITE_DIR=./site
